MOODYAI_ENV=production
MOODYAI_HOST=0.0.0.0
MOODYAI_DATA_DIR=/var/data
MOODYAI_SECURE_COOKIES=true
MOODYAI_FORWARDED_ALLOW_IPS=*
MOODYAI_LOG_LEVEL=INFO
MOODYAI_BACKGROUND_SYNC_ENABLED=true
MOODYAI_BACKUPS_ENABLED=true
MOODYAI_ADMIN_PASSWORD=replace-in-render-dashboard
MOODYAI_SESSION_SECRET=generate-at-least-32-random-characters
FOLLOWUPBOSS_API_KEY=replace-in-render-dashboard
OPENAI_API_KEY=optional

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>MoodyAI — Next Actions</title>
<style>
:root{color-scheme:dark;--bg:#090b0d;--panel:#111519;--panel2:#151a1f;--line:#293039;--text:#eef2f4;--muted:#9aa5ad;--accent:#84a7d8;--ok:#8bbf9f;--warn:#d3b778}
*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font:15px/1.45 -apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}.wrap{max-width:1180px;margin:0 auto;padding:28px}.top{display:flex;align-items:center;justify-content:space-between;gap:20px;margin-bottom:22px}.brand h1{font-size:22px;margin:0 0 4px}.brand p{margin:0;color:var(--muted)}button{background:#1b2229;border:1px solid var(--line);color:var(--text);border-radius:8px;padding:10px 14px;font-weight:650;cursor:pointer}button.primary{background:#273b53;border-color:#3b5878}.status{color:var(--muted);font-size:13px}.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px}.metric{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:15px}.metric .k{color:var(--muted);font-size:12px;text-transform:uppercase;letter-spacing:.05em}.metric .v{font-size:25px;font-weight:750;margin-top:5px}.layout{display:grid;grid-template-columns:350px 1fr;gap:16px}.panel{background:var(--panel);border:1px solid var(--line);border-radius:12px;overflow:hidden}.panel-head{padding:16px 18px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center}.panel-head h2{font-size:15px;margin:0}.queue{max-height:680px;overflow:auto}.lead{padding:15px 18px;border-bottom:1px solid var(--line);cursor:pointer}.lead:hover,.lead.active{background:var(--panel2)}.lead-top{display:flex;justify-content:space-between;gap:12px}.name{font-weight:700}.badge{font-size:11px;padding:3px 7px;border-radius:999px;border:1px solid var(--line);color:var(--muted)}.meta,.small{color:var(--muted);font-size:13px}.detail{padding:20px}.hero{background:var(--panel2);border:1px solid var(--line);border-radius:10px;padding:18px;margin-bottom:14px}.eyebrow{color:var(--accent);font-size:12px;text-transform:uppercase;letter-spacing:.08em;font-weight:750}.hero h3{font-size:22px;margin:7px 0 8px}.reason{color:var(--muted)}.timeline{display:grid;gap:12px}.step{border:1px solid var(--line);border-radius:10px;padding:16px}.step-title{font-size:12px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);font-weight:750;margin-bottom:7px}.done{color:var(--ok)}.waiting{color:var(--warn)}.choices{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}.empty{padding:35px;color:var(--muted);text-align:center}.footer{margin-top:14px;color:var(--muted);font-size:12px}@media(max-width:850px){.metrics{grid-template-columns:repeat(2,1fr)}.layout{grid-template-columns:1fr}.queue{max-height:320px}}
</style>
</head>
<body><div class="wrap">
<div class="top"><div class="brand"><h1>MoodyAI</h1><p>What to do next — with Follow Up Boss activity tracked automatically.</p></div><div><button id="refresh">Refresh</button><div id="system" class="status"></div></div></div>
<div id="metrics" class="metrics"></div>
<div class="layout">
<section class="panel"><div class="panel-head"><h2>Priority leads</h2><span id="count" class="badge"></span></div><div id="queue" class="queue"></div></section>
<section class="panel"><div class="panel-head"><h2>Next action</h2><span id="state" class="badge"></span></div><div id="detail" class="detail"></div></section>
</div>
<div class="footer">MoodyAI records calls and texts detected in Follow Up Boss. You only need to answer when the result is not clear from FUB.</div>
</div>
<script>
const $=id=>document.getElementById(id);const state={leads:[],selected:0,summary:{}};
async function api(path,options={}){const r=await fetch(path,{headers:{"Content-Type":"application/json",...(options.headers||{})},...options});const t=await r.text();let d={};try{d=t?JSON.parse(t):{}}catch{throw new Error(t||`HTTP ${r.status}`)}if(!r.ok)throw new Error(d.detail||`HTTP ${r.status}`);return d}
function esc(v){return String(v??"").replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]))}
function arr(p){return Array.isArray(p)?p:(p.items||p.leads||[])}
function current(l){if(l.outcome)return {label:"Result recorded",text:labelOutcome(l.outcome.outcome_type)};if(l.execution)return {label:"Action detected",text:`${cap(l.execution.action_type)} completed in ${l.execution.external_system==='follow_up_boss'?'Follow Up Boss':'MoodyAI'}`};return {label:"Recommended",text:"Waiting for action in Follow Up Boss"}}
function cap(s){s=String(s||"");return s.charAt(0).toUpperCase()+s.slice(1).replaceAll('_',' ')}
function labelOutcome(x){return ({replied:"Lead replied",qualified_conversation:"Qualified conversation",appointment_booked:"Appointment booked",active_client:"Active client",under_contract:"Under contract",closed:"Closed",no_response:"No response",not_interested:"Not interested",already_has_agent:"Already has an agent",wrong_number:"Wrong number",invalid_lead:"Invalid lead"})[x]||cap(x)}
function renderMetrics(){const s=state.summary||{};$('metrics').innerHTML=[['Recommendations',s.recommendations||0],['Actions detected',s.executed||0],['Results measured',s.evaluated||0],['Response rate',s.response_rate==null?'—':Math.round(s.response_rate*100)+'%']].map(([k,v])=>`<div class="metric"><div class="k">${esc(k)}</div><div class="v">${esc(v)}</div></div>`).join('')}
function renderQueue(){ $('count').textContent=`${state.leads.length} leads`; $('queue').innerHTML=state.leads.map((l,i)=>{const c=current(l);return `<div class="lead ${i===state.selected?'active':''}" data-i="${i}"><div class="lead-top"><div class="name">${esc(l.name)}</div><span class="badge">${esc(l.temperature)} ${esc(l.score)}</span></div><div class="meta">${esc(l.stage)} · ${esc(l.source)}</div><div class="small">${esc(c.text)}</div></div>`}).join('')||'<div class="empty">No lead recommendations available.</div>';document.querySelectorAll('.lead').forEach(e=>e.onclick=()=>{state.selected=Number(e.dataset.i);renderQueue();renderDetail()})}
function renderDetail(){const l=state.leads[state.selected];if(!l){$('detail').innerHTML='<div class="empty">Select a lead.</div>';return}const c=current(l);$('state').textContent=c.label;let result='';if(l.outcome){result=`<div class="done"><strong>${esc(labelOutcome(l.outcome.outcome_type))}</strong></div><div class="small">Recorded ${esc(l.outcome.observed_at||'')}</div>`}else if(l.execution){result=`<div class="waiting"><strong>MoodyAI detected the action, but the result is not clear yet.</strong></div><div class="small">Choose one only when you know what happened.</div><div class="choices">${[['replied','Replied'],['appointment_booked','Appointment booked'],['no_response','No response'],['not_interested','Not interested']].map(([v,t])=>`<button onclick="saveOutcome('${encodeURIComponent(l.recommendation_id)}','${v}')">${t}</button>`).join('')}</div>`}else{result='<div class="small">Nothing to enter here. Make the call or send the text in Follow Up Boss; MoodyAI will detect it on refresh.</div>'}
$('detail').innerHTML=`<div class="hero"><div class="eyebrow">Recommended next step</div><h3>${esc(l.recommendedAction||'Review this lead today.')}</h3><div class="reason">${esc(l.temperature)} priority · score ${esc(l.score)} · ${esc(l.stage)}</div></div><div class="timeline"><div class="step"><div class="step-title">What MoodyAI detected</div>${l.execution?`<div class="done"><strong>${esc(cap(l.execution.action_type))} completed</strong></div><div class="small">${esc(l.execution.performed_at||'')} · ${esc(l.execution.external_system||'')}</div>`:'<div class="small">No matching call or text detected in Follow Up Boss yet.</div>'}</div><div class="step"><div class="step-title">Current result</div>${result}</div></div>`}
async function saveOutcome(rid,type){try{await api(`/api/recommendations/${rid}/outcomes`,{method:'POST',body:JSON.stringify({outcome_type:type,source:'manual',attribution_confidence:1,notes:'Confirmed from simplified MoodyAI console.'})});await refresh()}catch(e){$('system').textContent=e.message}}
async function refresh(){const old=state.leads[state.selected]?.recommendation_id;$('system').textContent='Syncing Follow Up Boss…';try{const sync=await api('/api/learning/fub-sync/auto',{method:'POST'});const [leads,summary]=await Promise.all([api('/api/leads'),api('/api/learning/summary')]);state.leads=arr(leads);state.summary=summary;if(old){const idx=state.leads.findIndex(x=>x.recommendation_id===old);if(idx>=0)state.selected=idx}renderMetrics();renderQueue();renderDetail();$('system').textContent=`Synced · ${sync.imported_count||0} new action(s)`}catch(e){$('system').textContent=e.message}}
$('refresh').onclick=refresh;refresh();
</script></body></html>
